{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!manifest\\.json|icon-.*\\.svg|assets/.*|firmas/.*|sw\\.js|workbox-.*\\.js|favicon.*|contratos|contratos\\.html|contrato|contrato\\.html|llave|llave\\.html).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
