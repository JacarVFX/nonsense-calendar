{
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://nonsense-calendar.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://nonsense-calendar.firebaseapp.com/__/firebase/:path*"
    },
    {
      "source": "/((?!manifest\\.json|icon-.*\\.svg|assets/.*|sw\\.js|workbox-.*\\.js|favicon.*|__/.*).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
